# Fill these in one by one as you create each AWS service

# --- Step 1: Basic ---
PORT=3000
BASE_URL=http://localhost:3000      # Replace with EC2 public IP later
AWS_REGION=us-east-1

# --- Step 2: RDS (after creating RDS MySQL instance) ---
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your_password_here
DB_NAME=urlshortener

# --- Step 3: SQS (after creating the queue) ---
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/url-clicks

# --- Step 4: DynamoDB (table name used in Lambda) ---
DYNAMO_TABLE=url_analytics
